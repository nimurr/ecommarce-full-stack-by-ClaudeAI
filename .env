# ==================================
# ELECTRONICS ECOMMERCE - ENVIRONMENT CONFIGURATION
# ==================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ==================================
# SERVER CONFIGURATION
# ==================================
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000/api

VITE_API_URL=http://localhost:5000/api

# ==================================
# DATABASE (MongoDB Atlas or Local)
# ==================================
# For MongoDB Atlas (Recommended):

MONGODB_URI=mongodb+srv://gadgetslagbe:gadgetslagbe123@cluster0.xnsdt9c.mongodb.net/?appName=Cluster0
# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/electronics_ecommerce

# ==================================
# JWT SECRET (Generate a strong random string)
# ==================================
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_64_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ==================================
# CLOUDINARY IMAGE UPLOAD (Recommended for production)
# ==================================
# Sign up at: https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==================================
# STEADFAST COURIER API INTEGRATION
# ==================================
# Sign up at: https://steadfast.com.bd/
# Get API credentials from your dashboard
STEADFAST_API_KEY=your_steadfast_api_key
STEADFAST_API_SECRET=your_steadfast_api_secret
STEADFAST_BASE_URL=https://api.steadfast.com.bd/api/v1

# ==================================
# SMS GATEWAY INTEGRATION (SSL Wireless)
# ==================================
# Sign up at: https://sslwireless.com/
# Get API credentials from your dashboard
SSL_WIRELESS_API_KEY=your_ssl_wireless_api_key
SSL_WIRELESS_API_SECRET=your_ssl_wireless_api_secret
SSL_WIRELESS_SID=your_ssl_wireless_sid
SSL_WIRELESS_BASE_URL=https://api.sslwireless.com/smsapi

# Alternative: BulkSMSBD
# Sign up at: https://bulksmsbd.com/
# BULK_SMS_BD_API_KEY=43A0x5lzJqTOpFEQlXGa
# BULK_SMS_BD_SENDER_ID=8809648907593
 
# ==================================
# SSLCOMMERZ PAYMENT GATEWAY (Optional)
# ==================================
# Sign up at: https://sslcommerz.com/
# Get sandbox credentials for testing
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com/gwprocess/v3/api.php
# For production: https://securepay.sslcommerz.com/gwprocess/v3/api.php

# ==================================
# EMAIL CONFIGURATION (For notifications)
# ==================================
# Using Gmail (App Password required)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourelectronicsstore.com

# Alternative: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# ==================================
# FRONTEND URLs
# ==================================
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ==================================
# SECURITY & RATE LIMITING
# ==================================
# Rate limiter settings (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=20

# ==================================
# FILE UPLOAD SETTINGS
# ==================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ==================================
# STRIPE (Alternative Payment - Optional)
# ==================================
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ==================================
# REDIS (Optional - For caching & sessions)
# ==================================
# REDIS_URL=redis://localhost:6379
# REDIS_PORT=6379

# ==================================
# ANALYTICS & MONITORING (Optional)
# ==================================
# SENTRY_DSN=your_sentry_dsn
# GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
